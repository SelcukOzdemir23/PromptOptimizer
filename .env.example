# EvoPrompt Optimizer - Environment Configuration
# Copy this file to .env and fill in your values

# Groq API Key (Required)
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_api_key_here

# Model Configuration (llama-3.3-70b: best balance of speed & accuracy)
# Alternatives: llama-3.1-8b-instant (faster), mixtral-8x7b-32768, gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile

# Evolution Parameters
POPULATION_SIZE=20
GENERATIONS=10
MUTATION_PROBABILITY=0.2
CROSSOVER_PROBABILITY=0.8
TOURNAMENT_SIZE=3
MINI_BATCH_SIZE=50

# Rate Limiting
API_CALL_DELAY=1.0
API_MAX_RETRIES=3
API_BACKOFF_FACTOR=2.0

# Data Split
TEST_SPLIT_RATIO=0.5
RANDOM_SEED=42

# Final test evaluation sample size (-1 for full test set)
TEST_SAMPLE_SIZE=50
