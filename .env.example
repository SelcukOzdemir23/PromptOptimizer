# EvoPrompt Optimizer - Environment Configuration
# Copy this file to .env and fill in your values

# Google Gemini API Key (Required)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Model Configuration (Gemini 2.5 Flash-Lite: latest, fastest & cheapest for classification)
GEMINI_MODEL=gemini-2.5-flash-lite

# Evolution Parameters
POPULATION_SIZE=20
GENERATIONS=10
MUTATION_PROBABILITY=0.2
CROSSOVER_PROBABILITY=0.8
TOURNAMENT_SIZE=3
MINI_BATCH_SIZE=50

# Rate Limiting
API_CALL_DELAY=4.0
API_MAX_RETRIES=3
API_BACKOFF_FACTOR=2.0

# Data Split
TEST_SPLIT_RATIO=0.5
RANDOM_SEED=42
