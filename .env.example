# EvoPrompt Optimizer - Environment Configuration
# Copy this file to .env and fill in your values

# Ollama Configuration (local, no API key needed!)
# Make sure Ollama is running: ollama serve
# Model must be installed: ollama pull llama3.1:8b
# Alternatives: gemma2:9b, mistral:7b, qwen2.5:7b
OLLAMA_MODEL=llama3.1:8b

# Evolution Parameters
POPULATION_SIZE=20
GENERATIONS=10
MUTATION_PROBABILITY=0.2
CROSSOVER_PROBABILITY=0.8
TOURNAMENT_SIZE=3
MINI_BATCH_SIZE=50

# Rate Limiting (local inference — can be very fast)
API_CALL_DELAY=0.5
API_MAX_RETRIES=3
API_BACKOFF_FACTOR=2.0

# Data Split
TEST_SPLIT_RATIO=0.5
RANDOM_SEED=42

# Final test evaluation sample size (-1 for full test set)
TEST_SAMPLE_SIZE=50
